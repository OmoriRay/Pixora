<Window x:Class="Pixora.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:Pixora.Controls"
        xmlns:local="clr-namespace:Pixora"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="{x:Static local:AppInfo.Name}"
        Width="1100"
        Height="760"
        MinWidth="640"
        MinHeight="420"
        Background="#101216"
        Foreground="#F2F5F7"
        FontFamily="Microsoft YaHei UI"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType"
        TextOptions.TextHintingMode="Fixed"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        Focusable="True"
        InputMethod.IsInputMethodEnabled="False"
        Loaded="Window_Loaded"
        Closing="Window_Closing"
        PreviewKeyDown="Window_KeyDown"
        PreviewMouseDown="Window_PreviewMouseDown"
        AllowDrop="True"
        PreviewDragOver="Window_PreviewDragOver"
        Drop="Window_Drop"
        PreviewMouseWheel="Window_PreviewMouseWheel"
        StateChanged="Window_StateChanged">
    <Window.Resources>
        <SolidColorBrush x:Key="MenuBackgroundBrush" Color="#242832" />
        <SolidColorBrush x:Key="MenuBorderBrush" Color="#3A404C" />
        <SolidColorBrush x:Key="MenuForegroundBrush" Color="#F2F5F7" />
        <SolidColorBrush x:Key="MenuHoverBrush" Color="#313847" />
        <SolidColorBrush x:Key="MenuDisabledForegroundBrush" Color="#788290" />

        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#313847" />
        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="#FFFFFF" />
        <SolidColorBrush x:Key="{x:Static SystemColors.MenuBrushKey}" Color="#242832" />
        <SolidColorBrush x:Key="{x:Static SystemColors.MenuTextBrushKey}" Color="#F2F5F7" />
        <SolidColorBrush x:Key="{x:Static SystemColors.GrayTextBrushKey}" Color="#788290" />

        <DrawingBrush x:Key="CheckerBrush"
                      Viewport="0,0,32,32"
                      ViewportUnits="Absolute"
                      TileMode="Tile">
            <DrawingBrush.Drawing>
                <DrawingGroup>
                    <GeometryDrawing Brush="#171A20">
                        <GeometryDrawing.Geometry>
                            <RectangleGeometry Rect="0,0,32,32" />
                        </GeometryDrawing.Geometry>
                    </GeometryDrawing>
                    <GeometryDrawing Brush="#20242C">
                        <GeometryDrawing.Geometry>
                            <GeometryGroup>
                                <RectangleGeometry Rect="0,0,16,16" />
                                <RectangleGeometry Rect="16,16,16,16" />
                            </GeometryGroup>
                        </GeometryDrawing.Geometry>
                    </GeometryDrawing>
                </DrawingGroup>
            </DrawingBrush.Drawing>
        </DrawingBrush>

        <Style TargetType="{x:Type ContextMenu}">
            <Setter Property="Background" Value="{StaticResource MenuBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource MenuBorderBrush}" />
            <Setter Property="Foreground" Value="{StaticResource MenuForegroundBrush}" />
            <Setter Property="FontFamily" Value="Microsoft YaHei UI" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="TextOptions.TextFormattingMode" Value="Display" />
            <Setter Property="TextOptions.TextRenderingMode" Value="ClearType" />
            <Setter Property="TextOptions.TextHintingMode" Value="Fixed" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="Padding" Value="4" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ContextMenu}">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Cycle" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="{x:Type MenuItem}">
            <Setter Property="Foreground" Value="{StaticResource MenuForegroundBrush}" />
            <Setter Property="FontFamily" Value="Microsoft YaHei UI" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="TextOptions.TextFormattingMode" Value="Display" />
            <Setter Property="TextOptions.TextRenderingMode" Value="ClearType" />
            <Setter Property="TextOptions.TextHintingMode" Value="Fixed" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="Padding" Value="14,8" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type MenuItem}">
                        <Border x:Name="MenuItemChrome"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter ContentSource="Header"
                                              RecognizesAccessKey="True" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsHighlighted" Value="True">
                    <Setter Property="Background" Value="{StaticResource MenuHoverBrush}" />
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Foreground" Value="{StaticResource MenuDisabledForegroundBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="{x:Type Separator}">
            <Setter Property="Margin" Value="10,5" />
            <Setter Property="Background" Value="#4A5260" />
        </Style>

    </Window.Resources>

    <Grid x:Name="Root"
          Background="#101216">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition x:Name="ThumbnailSidebarColumn" Width="196" />
        </Grid.ColumnDefinitions>

        <Grid x:Name="ViewerSurface"
              Grid.Column="0"
              Background="{StaticResource CheckerBrush}"
              ClipToBounds="True"
              MouseLeftButtonDown="ViewerSurface_MouseLeftButtonDown"
              MouseLeftButtonUp="ViewerSurface_MouseLeftButtonUp"
              MouseMove="ViewerSurface_MouseMove"
              MouseDown="ViewerSurface_MouseDown"
              SizeChanged="ViewerSurface_SizeChanged">
            <Grid.ContextMenu>
                <ContextMenu Opened="ContextMenu_Opened">
                    <MenuItem x:Name="OpenImageMenuItem" Header="打开图片" Click="OpenImageMenuItem_Click" />
                    <MenuItem x:Name="OpenFolderMenuItem" Header="打开目录" Click="OpenFolderMenuItem_Click" />
                    <Separator />
                    <MenuItem x:Name="FavoriteMenuItem" Header="加入收藏" Click="FavoriteMenuItem_Click" />
                    <MenuItem x:Name="FavoritesViewMenuItem" Header="只看收藏" Click="FavoritesViewMenuItem_Click" />
                    <MenuItem x:Name="SetAsWallpaperMenuItem" Header="设为桌面壁纸" Visibility="Collapsed" Click="SetAsWallpaperMenuItem_Click" />
                    <Separator />
                    <MenuItem x:Name="CropMenuItem" Header="裁剪图片" Click="CropMenuItem_Click" />
                    <MenuItem x:Name="CircleCropMenuItem" Header="圆形裁剪" Click="CircleCropMenuItem_Click" />
                    <MenuItem x:Name="CompressMenuItem" Header="压缩图片" Click="CompressMenuItem_Click" />
                    <MenuItem x:Name="OpenBatchCompressToolsMenuItem" Header="批量压缩图片" Click="OpenBatchCompressToolsMenuItem_Click" />
                    <MenuItem x:Name="SaveVideoCoverMenuItem" Header="另存视频封面" Visibility="Collapsed" Click="SaveVideoCoverMenuItem_Click" />
                    <Separator />
                    <MenuItem x:Name="BatchDeleteMenuItem" Header="批量删除当前目录媒体" Click="BatchDeleteMenuItem_Click" />
                    <MenuItem x:Name="CopyFileMenuItem" Header="复制图片文件" Click="CopyFileMenuItem_Click" />
                    <MenuItem x:Name="CopyNameMenuItem" Header="复制文件名" Click="CopyNameMenuItem_Click" />
                    <MenuItem x:Name="CopyPathMenuItem" Header="复制文件路径" Click="CopyPathMenuItem_Click" />
                    <MenuItem x:Name="CopyDiagnosticsMenuItem" Header="复制诊断信息" Click="CopyDiagnosticsMenuItem_Click" />
                    <MenuItem x:Name="OpenContainingFolderMenuItem" Header="打开文件位置" Click="OpenContainingFolderMenuItem_Click" />
                    <Separator />
                    <MenuItem x:Name="ToggleInfoMenuItem" Header="显示/隐藏图片信息" Click="ToggleInfoMenuItem_Click" />
                    <MenuItem x:Name="ToggleThumbnailSidebarMenuItem" Header="隐藏缩略图栏" Click="ToggleThumbnailSidebarMenuItem_Click" />
                    <MenuItem x:Name="ShortcutSettingsMenuItem" Header="设置" Click="ShortcutSettingsMenuItem_Click" />
                </ContextMenu>
            </Grid.ContextMenu>

            <controls:BitmapViewer x:Name="BitmapView"
                                   HorizontalAlignment="Stretch"
                                   VerticalAlignment="Stretch"
                                   IsHitTestVisible="False"
                                   RenderOptions.BitmapScalingMode="HighQuality"
                                   SnapsToDevicePixels="False"
                                   UseLayoutRounding="False" />

            <Grid x:Name="CropOverlay"
                  Background="#33000000"
                  Panel.ZIndex="20"
                  Visibility="Collapsed"
                  IsHitTestVisible="False">
                <Canvas>
                    <Canvas.Resources>
                        <Style x:Key="CropHandleStyle" TargetType="{x:Type Border}">
                            <Setter Property="Width" Value="12" />
                            <Setter Property="Height" Value="12" />
                            <Setter Property="Background" Value="#F4F6F8" />
                            <Setter Property="BorderBrush" Value="#101216" />
                            <Setter Property="BorderThickness" Value="1" />
                            <Setter Property="CornerRadius" Value="6" />
                            <Setter Property="Visibility" Value="Collapsed" />
                        </Style>
                    </Canvas.Resources>
                    <Border x:Name="CropSelection"
                            Background="#20FFFFFF"
                            BorderBrush="#F4F6F8"
                            BorderThickness="2"
                            CornerRadius="4"
                            Visibility="Collapsed" />
                    <Ellipse x:Name="CropCircleSelection"
                             Fill="#20FFFFFF"
                             Stroke="#F4F6F8"
                             StrokeThickness="2"
                             Visibility="Collapsed" />
                    <Border x:Name="CropHandleTopLeft" Style="{StaticResource CropHandleStyle}" />
                    <Border x:Name="CropHandleTop" Style="{StaticResource CropHandleStyle}" />
                    <Border x:Name="CropHandleTopRight" Style="{StaticResource CropHandleStyle}" />
                    <Border x:Name="CropHandleRight" Style="{StaticResource CropHandleStyle}" />
                    <Border x:Name="CropHandleBottomRight" Style="{StaticResource CropHandleStyle}" />
                    <Border x:Name="CropHandleBottom" Style="{StaticResource CropHandleStyle}" />
                    <Border x:Name="CropHandleBottomLeft" Style="{StaticResource CropHandleStyle}" />
                    <Border x:Name="CropHandleLeft" Style="{StaticResource CropHandleStyle}" />
                </Canvas>

                <Border HorizontalAlignment="Center"
                        VerticalAlignment="Top"
                        Margin="0,18,0,0"
                        Background="#E0101216"
                        BorderBrush="#425064"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="14,8">
                    <TextBlock Text="裁剪：拖出区域，可拖动边角调整，Enter 保存，Esc 取消"
                               Foreground="#F2F5F7"
                               FontSize="13"
                               TextWrapping="NoWrap" />
                </Border>
            </Grid>

            <Border x:Name="EmptyPanel"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Background="#B0101216"
                    BorderBrush="#33404D"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="20,14">
                <StackPanel Orientation="Horizontal">
                    <Button Content="打开图片"
                            Padding="18,8"
                            Margin="0,0,10,0"
                            Click="OpenImageMenuItem_Click" />
                    <Button Content="打开目录"
                            Padding="18,8"
                            Click="OpenFolderMenuItem_Click" />
                </StackPanel>
            </Border>

            <Border x:Name="ErrorPanel"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Background="#E0181B21"
                    BorderBrush="#5A6574"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="20,16"
                    MaxWidth="720"
                    Visibility="Collapsed">
                <TextBlock x:Name="ErrorText"
                           Foreground="#F4F6F8"
                           FontSize="14"
                           TextWrapping="Wrap" />
            </Border>

            <Border x:Name="LoadingPanel"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Background="#D0181B21"
                    BorderBrush="#3B4654"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="18,12"
                    Visibility="Collapsed">
                <StackPanel>
                    <TextBlock x:Name="LoadingText"
                               Text="正在打开..."
                               Foreground="#E6EBF0"
                               FontSize="14"
                               TextAlignment="Center" />
                    <Button x:Name="CancelFolderLoadButton"
                            Content="取消扫描"
                            Margin="0,10,0,0"
                            MinWidth="88"
                            HorizontalAlignment="Center"
                            Visibility="Collapsed"
                            Click="CancelFolderLoadButton_Click" />
                </StackPanel>
            </Border>

            <Border x:Name="CatalogScanPanel"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Margin="14"
                    Background="#E0181B21"
                    BorderBrush="#3B4654"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="10,7"
                    Visibility="Collapsed">
                <StackPanel Orientation="Horizontal">
                    <TextBlock x:Name="CatalogScanText"
                               Text="正在补齐目录..."
                               AutomationProperties.LiveSetting="Polite"
                               VerticalAlignment="Center"
                               Foreground="#E6EBF0"
                               FontSize="12" />
                    <Button Content="取消"
                            AutomationProperties.Name="取消目录补齐"
                            Margin="8,0,0,0"
                            MinWidth="48"
                            MinHeight="26"
                            Padding="8,3"
                            Click="CancelCatalogCompletionButton_Click" />
                </StackPanel>
            </Border>

            <Border x:Name="ZoomIndicator"
                    AutomationProperties.LiveSetting="Polite"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    Margin="14"
                    MinWidth="66"
                    Background="#D8101216"
                    BorderBrush="#526070"
                    BorderThickness="1"
                    CornerRadius="9"
                    Padding="12,7"
                    Opacity="0"
                    Visibility="Collapsed"
                    IsHitTestVisible="False"
                    Panel.ZIndex="50">
                <TextBlock x:Name="ZoomIndicatorText"
                           HorizontalAlignment="Center"
                           Foreground="#F4F7FA"
                           FontSize="14"
                           FontWeight="SemiBold"
                           Text="100%"
                           TextWrapping="NoWrap" />
            </Border>

            <Border x:Name="VideoBadge"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    Margin="14"
                    Background="#D8171C24"
                    BorderBrush="#4B5665"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="10,6"
                    Visibility="Collapsed"
                    IsHitTestVisible="False">
                <TextBlock Text="视频封面"
                           Foreground="#F2F5F7"
                           FontSize="13"
                           FontWeight="SemiBold" />
            </Border>

            <Border x:Name="AnimationControlPanel"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    Margin="14,56,14,14"
                    Background="#D8171C24"
                    BorderBrush="#4B5665"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="8"
                    Visibility="Collapsed">
                <StackPanel Orientation="Horizontal">
                    <Button x:Name="ToggleAnimationButton"
                            Content="暂停"
                            MinWidth="58"
                            Padding="10,5"
                            Margin="0,0,6,0"
                            Click="ToggleAnimationButton_Click" />
                    <Button x:Name="RestartAnimationButton"
                            Content="重播"
                            MinWidth="58"
                            Padding="10,5"
                            Click="RestartAnimationButton_Click" />
                </StackPanel>
            </Border>

            <Border x:Name="InfoPanel"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Bottom"
                    Margin="14"
                    Background="#D8101216"
                    BorderBrush="#26313C"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="12,9">
                <TextBlock x:Name="InfoText"
                           Foreground="#E8ECF0"
                           FontSize="13"
                           TextWrapping="NoWrap" />
            </Border>

            <Border x:Name="BoundaryToast"
                    AutomationProperties.LiveSetting="Polite"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Top"
                    Margin="0,18,0,0"
                    Background="#D8101216"
                    BorderBrush="#2F3B48"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="16,9"
                    Opacity="0"
                    Visibility="Collapsed"
                    IsHitTestVisible="False">
                <TextBlock x:Name="BoundaryToastText"
                           Foreground="#F2F5F7"
                           FontSize="14"
                           TextWrapping="NoWrap" />
            </Border>
        </Grid>

        <Border x:Name="ThumbnailSidebar"
                Grid.Column="1"
                Background="#181C23"
                BorderBrush="#2A323E"
                BorderThickness="1,0,0,0">
            <Border.ContextMenu>
                <ContextMenu Opened="ContextMenu_Opened">
                    <MenuItem x:Name="SortByNameMenuItem" Header="排序：按名称" Click="SortByNameMenuItem_Click" />
                    <MenuItem x:Name="SortByNameDescendingMenuItem" Header="排序：按名称倒序" Click="SortByNameDescendingMenuItem_Click" />
                    <MenuItem x:Name="SortByNewestMenuItem" Header="排序：按修改时间（新到旧）" Click="SortByNewestMenuItem_Click" />
                    <MenuItem x:Name="SortByOldestMenuItem" Header="排序：按修改时间（旧到新）" Click="SortByOldestMenuItem_Click" />
                    <MenuItem x:Name="SortByLargestMenuItem" Header="排序：按文件大小（大到小）" Click="SortByLargestMenuItem_Click" />
                    <MenuItem x:Name="SortBySmallestMenuItem" Header="排序：按文件大小（小到大）" Click="SortBySmallestMenuItem_Click" />
                </ContextMenu>
            </Border.ContextMenu>
            <DockPanel>
                <Border DockPanel.Dock="Top"
                        BorderBrush="#2A323E"
                        BorderThickness="0,0,0,1"
                        Padding="10,8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="ThumbnailSidebarTitle"
                                   Grid.Column="0"
                                   VerticalAlignment="Center"
                                   Text="图片预览"
                                   Foreground="#E8ECF0"
                                   FontSize="13"
                                   FontWeight="SemiBold" />
                        <Button x:Name="ThumbnailColumnToggleButton"
                                Grid.Column="1"
                                Content="双列"
                                MinWidth="44"
                                MinHeight="26"
                                Padding="8,3"
                                FontSize="12"
                                AutomationProperties.Name="切换缩略图列数"
                                Click="ToggleThumbnailColumnsMenuItem_Click" />
                    </Grid>
                </Border>

                <ListBox x:Name="ThumbnailList"
                         AutomationProperties.Name="当前目录缩略图"
                         AutomationProperties.HelpText="使用上一张和下一张快捷键浏览图片"
                         Background="Transparent"
                         BorderThickness="0"
                         Foreground="#F2F5F7"
                         Padding="8,4,4,4"
                         ScrollViewer.CanContentScroll="True"
                         VirtualizingPanel.IsVirtualizing="True"
                         VirtualizingPanel.VirtualizationMode="Recycling"
                         VirtualizingPanel.ScrollUnit="Item"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                         VirtualizingPanel.CacheLength="2"
                         VirtualizingPanel.CacheLengthUnit="Page">
                    <ListBox.Resources>
                        <Style x:Key="ThumbnailScrollBarButtonStyle" TargetType="{x:Type RepeatButton}">
                            <Setter Property="Focusable" Value="False" />
                            <Setter Property="IsTabStop" Value="False" />
                            <Setter Property="Width" Value="0" />
                            <Setter Property="Height" Value="0" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="{x:Type RepeatButton}">
                                        <Border Background="Transparent" />
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>

                        <Style TargetType="{x:Type Thumb}">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="{x:Type Thumb}">
                                        <Border x:Name="ThumbBorder"
                                                Margin="2"
                                                Background="#526070"
                                                CornerRadius="4" />
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="ThumbBorder" Property="Background" Value="#6D7E91" />
                                            </Trigger>
                                            <Trigger Property="IsDragging" Value="True">
                                                <Setter TargetName="ThumbBorder" Property="Background" Value="#78C8F8" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>

                        <Style TargetType="{x:Type ScrollBar}">
                            <Setter Property="Width" Value="12" />
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="{x:Type ScrollBar}">
                                        <Grid Background="{TemplateBinding Background}">
                                            <Border x:Name="ScrollTrack"
                                                    Background="#11151B"
                                                    CornerRadius="6"
                                                    Margin="2" />
                                            <Track x:Name="PART_Track"
                                                   Margin="2"
                                                   IsDirectionReversed="True">
                                                <Track.DecreaseRepeatButton>
                                                    <RepeatButton Style="{StaticResource ThumbnailScrollBarButtonStyle}"
                                                                  Command="ScrollBar.PageUpCommand" />
                                                </Track.DecreaseRepeatButton>
                                                <Track.Thumb>
                                                    <Thumb />
                                                </Track.Thumb>
                                                <Track.IncreaseRepeatButton>
                                                    <RepeatButton Style="{StaticResource ThumbnailScrollBarButtonStyle}"
                                                                  Command="ScrollBar.PageDownCommand" />
                                                </Track.IncreaseRepeatButton>
                                            </Track>
                                        </Grid>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="ScrollTrack" Property="Background" Value="#151B24" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.Resources>
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <VirtualizingStackPanel VirtualizationMode="Recycling" />
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="{x:Type ListBoxItem}">
                            <Setter Property="Focusable" Value="False" />
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            <Setter Property="VerticalContentAlignment" Value="Top" />
                            <Setter Property="Padding" Value="0" />
                            <Setter Property="Margin" Value="0" />
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="{x:Type ListBoxItem}">
                                        <ContentPresenter />
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <ItemsControl ItemsSource="{Binding Items}"
                                          HorizontalAlignment="Stretch"
                                          Margin="0,0,1.5,0">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <UniformGrid Rows="1"
                                                     Columns="{Binding DataContext.ThumbnailColumnCount, RelativeSource={RelativeSource AncestorType={x:Type ListBox}}}" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Width="{Binding DataContext.ThumbnailItemWidth, RelativeSource={RelativeSource AncestorType={x:Type ListBox}}}"
                                                HorizontalAlignment="Center"
                                                Margin="{Binding DataContext.ThumbnailItemMargin, RelativeSource={RelativeSource AncestorType={x:Type ListBox}}}"
                                                BorderThickness="1"
                                                CornerRadius="7"
                                                Cursor="Hand"
                                                Padding="{Binding DataContext.ThumbnailItemPadding, RelativeSource={RelativeSource AncestorType={x:Type ListBox}}}"
                                                MouseLeftButtonUp="ThumbnailCell_MouseLeftButtonUp">
                                            <Border.Style>
                                                <Style TargetType="{x:Type Border}">
                                                    <Setter Property="Background" Value="Transparent" />
                                                    <Setter Property="BorderBrush" Value="#00000000" />
                                                    <Style.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Background" Value="#242B36" />
                                                            <Setter Property="BorderBrush" Value="#3B4655" />
                                                        </Trigger>
                                                        <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                            <Setter Property="Background" Value="#26394B" />
                                                            <Setter Property="BorderBrush" Value="#65BFF2" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <StackPanel>
                                                <Border Height="{Binding DataContext.ThumbnailImageHeight, RelativeSource={RelativeSource AncestorType={x:Type ListBox}}}"
                                                        Background="#101216"
                                                        BorderBrush="#303846"
                                                        BorderThickness="1"
                                                        CornerRadius="6"
                                                        ClipToBounds="True">
                                                    <Grid>
                                                        <TextBlock Text="{Binding StatusText}"
                                                                   HorizontalAlignment="Center"
                                                                   VerticalAlignment="Center"
                                                                   Foreground="#748091"
                                                                   FontSize="11">
                                                            <TextBlock.Style>
                                                                <Style TargetType="{x:Type TextBlock}">
                                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding Thumbnail}" Value="{x:Null}">
                                                                            <Setter Property="Visibility" Value="Visible" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                        <Image Source="{Binding Thumbnail}"
                                                               Stretch="Uniform"
                                                               RenderOptions.BitmapScalingMode="HighQuality" />
                                                        <Border HorizontalAlignment="Left"
                                                                VerticalAlignment="Top"
                                                                Margin="5"
                                                                Background="#D8171C24"
                                                                BorderBrush="#5D6B7E"
                                                                BorderThickness="1"
                                                                CornerRadius="4"
                                                                Padding="5,2">
                                                            <Border.Style>
                                                                <Style TargetType="{x:Type Border}">
                                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsVideo}" Value="True">
                                                                            <Setter Property="Visibility" Value="Visible" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Border.Style>
                                                            <TextBlock Text="视频"
                                                                       Foreground="#F2F5F7"
                                                                       FontSize="10"
                                                                       FontWeight="SemiBold" />
                                                        </Border>
                                                        <Border HorizontalAlignment="Right"
                                                                VerticalAlignment="Top"
                                                                Margin="5"
                                                                Background="#DA27210F"
                                                                BorderBrush="#D9B24F"
                                                                BorderThickness="1"
                                                                CornerRadius="4"
                                                                Padding="4,1">
                                                            <Border.Style>
                                                                <Style TargetType="{x:Type Border}">
                                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsFavorite}" Value="True">
                                                                            <Setter Property="Visibility" Value="Visible" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Border.Style>
                                                            <TextBlock Text="★"
                                                                       Foreground="#FFD66B"
                                                                       FontSize="11"
                                                                       FontWeight="Bold" />
                                                        </Border>
                                                    </Grid>
                                                </Border>
                                                <TextBlock Text="{Binding FileName}"
                                                           Margin="0,4,0,0"
                                                           Foreground="#DCE4EC"
                                                           FontSize="11"
                                                           TextTrimming="CharacterEllipsis" />
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Border>

        <Grid x:Name="QuickSearchOverlay"
              Grid.ColumnSpan="2"
              Height="44"
              HorizontalAlignment="Stretch"
              VerticalAlignment="Top"
              Margin="0,28,0,0"
              Panel.ZIndex="200"
              Opacity="0"
              Visibility="Collapsed"
              IsHitTestVisible="False"
              RenderTransformOrigin="0.5,0">
            <Grid.RenderTransform>
                <TransformGroup>
                    <ScaleTransform x:Name="QuickSearchScaleTransform"
                                    ScaleX="0.96"
                                    ScaleY="0.96" />
                    <TranslateTransform x:Name="QuickSearchTranslateTransform"
                                        Y="-18" />
                </TransformGroup>
            </Grid.RenderTransform>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="27.5*" />
                <ColumnDefinition Width="45*" />
                <ColumnDefinition Width="27.5*" />
            </Grid.ColumnDefinitions>

            <Border x:Name="QuickSearchGlass"
                    Grid.Column="1"
                    MinWidth="360"
                    MaxWidth="640"
                    Background="#01000000"
                    BorderThickness="0"
                    CornerRadius="22"
                    Padding="0"
                    AutomationProperties.HelpText="按住 Ctrl 并拖动可调整快速搜索位置"
                    PreviewMouseLeftButtonDown="QuickSearchGlass_PreviewMouseLeftButtonDown"
                    PreviewMouseLeftButtonUp="QuickSearchGlass_PreviewMouseLeftButtonUp"
                    PreviewMouseMove="QuickSearchGlass_PreviewMouseMove"
                    LostMouseCapture="QuickSearchGlass_LostMouseCapture"
                    SizeChanged="QuickSearchGlass_SizeChanged">
                <Border.RenderTransform>
                    <TranslateTransform x:Name="QuickSearchPositionTransform" />
                </Border.RenderTransform>
                <Border.Effect>
                    <DropShadowEffect x:Name="QuickSearchShadow"
                                      BlurRadius="22"
                                      ShadowDepth="4"
                                      Direction="270"
                                      Color="#90000000"
                                      Opacity="0.34" />
                </Border.Effect>
                <Border.Triggers>
                    <EventTrigger RoutedEvent="MouseEnter">
                        <BeginStoryboard>
                            <Storyboard>
                                <ColorAnimation Storyboard.TargetName="QuickSearchTintBrush"
                                                Storyboard.TargetProperty="Color"
                                                To="#8A303940"
                                                Duration="0:0:0.14">
                                    <ColorAnimation.EasingFunction>
                                        <QuadraticEase EasingMode="EaseOut" />
                                    </ColorAnimation.EasingFunction>
                                </ColorAnimation>
                                <DoubleAnimation Storyboard.TargetName="QuickSearchBackdrop"
                                                 Storyboard.TargetProperty="Opacity"
                                                 To="0.66"
                                                 Duration="0:0:0.14" />
                                <DoubleAnimation Storyboard.TargetName="QuickSearchShadow"
                                                 Storyboard.TargetProperty="Opacity"
                                                 To="0.48"
                                                 Duration="0:0:0.14" />
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                    <EventTrigger RoutedEvent="MouseLeave">
                        <BeginStoryboard>
                            <Storyboard>
                                <ColorAnimation Storyboard.TargetName="QuickSearchTintBrush"
                                                Storyboard.TargetProperty="Color"
                                                To="#68505A62"
                                                Duration="0:0:0.18">
                                    <ColorAnimation.EasingFunction>
                                        <QuadraticEase EasingMode="EaseOut" />
                                    </ColorAnimation.EasingFunction>
                                </ColorAnimation>
                                <DoubleAnimation Storyboard.TargetName="QuickSearchBackdrop"
                                                 Storyboard.TargetProperty="Opacity"
                                                 To="0.78"
                                                 Duration="0:0:0.18" />
                                <DoubleAnimation Storyboard.TargetName="QuickSearchShadow"
                                                 Storyboard.TargetProperty="Opacity"
                                                 To="0.34"
                                                 Duration="0:0:0.18" />
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                </Border.Triggers>
                <Grid>
                    <Border x:Name="QuickSearchBackdrop"
                            Margin="1"
                            CornerRadius="21"
                            Opacity="0.78"
                            IsHitTestVisible="False">
                        <Border.CacheMode>
                            <BitmapCache RenderAtScale="1"
                                         EnableClearType="False" />
                        </Border.CacheMode>
                        <Border.Background>
                            <VisualBrush x:Name="QuickSearchBackdropBrush"
                                         Visual="{Binding ElementName=ViewerSurface}"
                                         ViewboxUnits="Absolute"
                                         Stretch="Fill" />
                        </Border.Background>
                        <Border.Effect>
                            <BlurEffect Radius="18"
                                        KernelType="Gaussian"
                                        RenderingBias="Quality" />
                        </Border.Effect>
                    </Border>

                    <Border Margin="1"
                            CornerRadius="21"
                            IsHitTestVisible="False">
                        <Border.Background>
                            <SolidColorBrush x:Name="QuickSearchTintBrush"
                                             Color="#68505A62" />
                        </Border.Background>
                    </Border>

                    <Border Margin="1"
                            CornerRadius="21"
                            IsHitTestVisible="False">
                        <Border.Background>
                            <RadialGradientBrush Center="0.18,0.08"
                                                 GradientOrigin="0.12,0.02"
                                                 RadiusX="0.95"
                                                 RadiusY="1.2">
                                <GradientStop Offset="0" Color="#38FFFFFF" />
                                <GradientStop Offset="0.42" Color="#10FFFFFF" />
                                <GradientStop Offset="1" Color="#10000000" />
                            </RadialGradientBrush>
                        </Border.Background>
                    </Border>

                    <Border Margin="1"
                            Background="Transparent"
                            BorderBrush="#55FFFFFF"
                            BorderThickness="1"
                            CornerRadius="21"
                            IsHitTestVisible="False" />

                    <Grid Margin="12,0"
                          KeyboardNavigation.TabNavigation="Cycle">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="82" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <Button x:Name="QuickSearchModeButton"
                                Grid.Column="0"
                                Width="78"
                                Height="38"
                                Padding="0"
                                Background="Transparent"
                                BorderThickness="0"
                                Focusable="True"
                                IsTabStop="True"
                                AutomationProperties.Name="按图片序号搜索"
                                Cursor="Hand"
                                Click="QuickSearchModeButton_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="{x:Type Button}">
                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center" />
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Opacity" Value="0.82" />
                                        </Trigger>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter Property="Opacity" Value="0.62" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                            <Button.Content>
                                <StackPanel Height="34"
                                            Orientation="Horizontal"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center">
                                    <Image Width="28"
                                           Height="28"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           RenderOptions.BitmapScalingMode="HighQuality">
                                        <Image.Source>
                                            <BitmapImage UriSource="/Pixora;component/Assets/PixoraIcon.png"
                                                         DecodePixelWidth="64"
                                                         CacheOption="OnLoad" />
                                        </Image.Source>
                                    </Image>
                                    <TextBlock x:Name="QuickSearchModeText"
                                               Margin="6,0,0,0"
                                               Text="序号"
                                               Foreground="#D9EFF2F5"
                                               FontSize="11"
                                               FontWeight="SemiBold"
                                               VerticalAlignment="Center" />
                                </StackPanel>
                            </Button.Content>
                        </Button>

                        <Grid Grid.Column="1"
                              Margin="4,0,0,0">
                            <TextBox x:Name="QuickSearchTextBox"
                                     Height="38"
                                     Padding="0,1"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     FocusVisualStyle="{x:Null}"
                                     Foreground="#FFFFFF"
                                     CaretBrush="Transparent"
                                     SelectionBrush="#58FFFFFF"
                                     FontSize="16"
                                     FontWeight="Normal"
                                     VerticalContentAlignment="Center"
                                     AutomationProperties.Name="快速搜索输入"
                                     AutomationProperties.HelpText="输入图片序号并按回车跳转"
                                     InputMethod.IsInputMethodEnabled="True"
                                     PreviewMouseLeftButtonDown="QuickSearchTextBox_PreviewMouseLeftButtonDown"
                                     LostKeyboardFocus="QuickSearchTextBox_LostKeyboardFocus"
                                     TextChanged="QuickSearchTextBox_TextChanged">
                                <TextBox.Template>
                                    <ControlTemplate TargetType="{x:Type TextBox}">
                                        <Border Background="Transparent"
                                                BorderThickness="0"
                                                Padding="{TemplateBinding Padding}">
                                            <ScrollViewer x:Name="PART_ContentHost"
                                                          Background="Transparent"
                                                          BorderThickness="0"
                                                          Focusable="False"
                                                          HorizontalScrollBarVisibility="Hidden"
                                                          VerticalScrollBarVisibility="Hidden" />
                                        </Border>
                                    </ControlTemplate>
                                </TextBox.Template>
                            </TextBox>
                        </Grid>

                        <TextBlock x:Name="QuickSearchHintText"
                                   Grid.Column="2"
                                   MaxWidth="180"
                                   Margin="12,0,14,0"
                                   Foreground="#D9EFF2F5"
                                   FontSize="11"
                                   AutomationProperties.LiveSetting="Polite"
                                   VerticalAlignment="Center"
                                   TextTrimming="CharacterEllipsis" />

                        <Button x:Name="QuickSearchGoButton"
                                Grid.Column="3"
                                Width="36"
                                Height="36"
                                Padding="0"
                                Background="Transparent"
                                BorderThickness="0"
                                Focusable="True"
                                IsTabStop="True"
                                AutomationProperties.Name="执行快速搜索"
                                Cursor="Hand"
                                ToolTip="跳转"
                                Click="QuickSearchGoButton_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="{x:Type Button}">
                                    <Border x:Name="GoButtonChrome"
                                            Background="Transparent"
                                            CornerRadius="18">
                                        <ContentPresenter HorizontalAlignment="Center"
                                                          VerticalAlignment="Center" />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="GoButtonChrome"
                                                    Property="Background"
                                                    Value="#24FFFFFF" />
                                        </Trigger>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter TargetName="GoButtonChrome"
                                                    Property="Background"
                                                    Value="#3CFFFFFF" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                            <Button.Content>
                                <TextBlock Text="→"
                                           Foreground="#EFFFFFFF"
                                           FontFamily="Segoe UI Variable Display, Microsoft YaHei UI"
                                           FontSize="22"
                                           FontWeight="SemiBold"
                                           Margin="0,-2,0,0" />
                            </Button.Content>
                        </Button>
                    </Grid>
                </Grid>
            </Border>
        </Grid>

    </Grid>
</Window>
