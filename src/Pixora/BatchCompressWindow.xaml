<Window x:Class="Pixora.BatchCompressWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="批量压缩图片"
        Width="860"
        Height="660"
        MinWidth="720"
        MinHeight="520"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource AppBackgroundBrush}"
        Foreground="{DynamicResource TextPrimaryBrush}"
        FontFamily="Microsoft YaHei UI"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType"
        TextOptions.TextHintingMode="Fixed"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        Closing="Window_Closing">
    <Window.Resources>
        <Style x:Key="SectionBorder" TargetType="{x:Type Border}">
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="14" />
        </Style>
        <Style x:Key="LabelText" TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Margin" Value="0,0,0,6" />
        </Style>

        <Style x:Key="BatchSliderDecreaseButton" TargetType="{x:Type RepeatButton}">
            <Setter Property="Focusable" Value="False" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type RepeatButton}">
                        <Border Height="6"
                                Background="{DynamicResource AccentBrush}"
                                CornerRadius="3"
                                VerticalAlignment="Center" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BatchSliderIncreaseButton" TargetType="{x:Type RepeatButton}">
            <Setter Property="Focusable" Value="False" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type RepeatButton}">
                        <Border Height="6"
                                Background="{DynamicResource BorderBrush}"
                                CornerRadius="3"
                                VerticalAlignment="Center" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BatchSliderThumb" TargetType="{x:Type Thumb}">
            <Setter Property="Width" Value="20" />
            <Setter Property="Height" Value="20" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Thumb}">
                        <Border x:Name="ThumbChrome"
                                Background="{DynamicResource SliderThumbBrush}"
                                BorderBrush="{DynamicResource AccentBrush}"
                                BorderThickness="2"
                                CornerRadius="10" />
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ThumbChrome" Property="Background" Value="{DynamicResource SliderThumbHoverBrush}" />
                                <Setter TargetName="ThumbChrome" Property="BorderBrush" Value="{DynamicResource AccentHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsDragging" Value="True">
                                <Setter TargetName="ThumbChrome" Property="Background" Value="{DynamicResource SliderThumbPressedBrush}" />
                                <Setter TargetName="ThumbChrome" Property="BorderBrush" Value="{DynamicResource AccentHoverBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BatchSlider" TargetType="{x:Type Slider}">
            <Setter Property="Height" Value="30" />
            <Setter Property="FocusVisualStyle" Value="{DynamicResource KeyboardFocusVisual}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Slider}">
                        <Grid VerticalAlignment="Center">
                            <Track x:Name="PART_Track">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="{x:Static Slider.DecreaseLarge}"
                                                  Style="{StaticResource BatchSliderDecreaseButton}" />
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource BatchSliderThumb}" />
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="{x:Static Slider.IncreaseLarge}"
                                                  Style="{StaticResource BatchSliderIncreaseButton}" />
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="{x:Type ProgressBar}">
            <Setter Property="Background" Value="{DynamicResource InputBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ProgressBar}">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                SnapsToDevicePixels="True">
                            <Grid x:Name="PART_Track"
                                  ClipToBounds="True">
                                <Border x:Name="PART_Indicator"
                                        HorizontalAlignment="Left"
                                        Background="{TemplateBinding Foreground}"
                                        CornerRadius="5" />
                            </Grid>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="{x:Type ListBox}">
            <Setter Property="Background" Value="{DynamicResource InputBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{DynamicResource TextBodyBrush}" />
            <Setter Property="Padding" Value="4" />
            <Setter Property="FocusVisualStyle" Value="{DynamicResource KeyboardFocusVisual}" />
        </Style>

        <Style TargetType="{x:Type ListBoxItem}">
            <Setter Property="Foreground" Value="{DynamicResource TextBodyBrush}" />
            <Setter Property="Padding" Value="8,5" />
            <Setter Property="FocusVisualStyle" Value="{DynamicResource KeyboardFocusVisual}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ListBoxItem}">
                        <Border x:Name="ItemChrome"
                                Background="Transparent"
                                CornerRadius="5"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemChrome" Property="Background" Value="{DynamicResource SurfaceHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemChrome" Property="Background" Value="{DynamicResource SelectionBrush}" />
                                <Setter Property="Foreground" Value="{DynamicResource SelectionTextBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Style="{StaticResource SectionBorder}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Text="输入"
                           Style="{StaticResource LabelText}" />
                <TextBox x:Name="InputPathText"
                         Grid.Row="1"
                         Height="40"
                         Padding="10,0"
                         TextChanged="InputPathText_TextChanged" />
                <Button Grid.Row="1"
                        Grid.Column="1"
                        Content="选文件"
                        MinWidth="76"
                        Margin="8,0,0,0"
                        Click="BrowseInputFileButton_Click" />
                <Button Grid.Row="1"
                        Grid.Column="2"
                        Content="选目录"
                        MinWidth="76"
                        Margin="8,0,0,0"
                        Click="BrowseInputFolderButton_Click" />
            </Grid>
        </Border>

        <Border Grid.Row="1"
                Style="{StaticResource SectionBorder}"
                Margin="0,12,0,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Text="输出目录"
                           Style="{StaticResource LabelText}" />
                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="84" />
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="OutputFolderText"
                             Height="40"
                             Padding="10,0"
                             TextChanged="OutputFolderText_TextChanged" />
                    <Button Grid.Column="1"
                            Content="浏览"
                            Margin="8,0,0,0"
                            Click="BrowseOutputFolderButton_Click" />
                </Grid>

                <Grid Grid.Row="2"
                      Margin="0,14,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="20" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="20" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock Text="格式"
                                   Style="{StaticResource LabelText}" />
                        <ComboBox x:Name="FormatComboBox"
                                  Height="40"
                                  SelectedIndex="0"
                                  SelectionChanged="FormatComboBox_SelectionChanged">
                            <ComboBoxItem Content="JPEG" Tag="Jpeg" />
                            <ComboBoxItem Content="PNG" Tag="Png" />
                        </ComboBox>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="质量"
                                   Style="{StaticResource LabelText}" />
                        <Grid Height="42">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="46" />
                            </Grid.ColumnDefinitions>
                            <Slider x:Name="QualitySlider"
                                    Minimum="1"
                                    Maximum="100"
                                    Value="82"
                                    TickFrequency="1"
                                    IsSnapToTickEnabled="True"
                                    Style="{StaticResource BatchSlider}"
                                    ValueChanged="QualitySlider_ValueChanged" />
                            <TextBlock x:Name="QualityText"
                                       Grid.Column="1"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center"
                                       TextAlignment="Right" />
                        </Grid>
                    </StackPanel>

                    <StackPanel Grid.Column="4">
                        <TextBlock Text="最大宽高"
                                   Style="{StaticResource LabelText}" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="24" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="MaxWidthText"
                                     Height="40"
                                     Padding="10,0"
                                     Text="1920" />
                            <TextBlock Grid.Column="1"
                                       Text="x"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       VerticalAlignment="Center"
                                       TextAlignment="Center" />
                            <TextBox x:Name="MaxHeightText"
                                     Grid.Column="2"
                                     Height="40"
                                     Padding="10,0"
                                     Text="1920" />
                        </Grid>
                    </StackPanel>
                </Grid>

                <Grid Grid.Row="3"
                      Margin="0,12,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <WrapPanel>
                        <CheckBox x:Name="IncludeSubfoldersCheckBox"
                                  Content="包含子目录"
                                  Margin="0,0,24,0" />
                        <CheckBox x:Name="OverwriteExistingCheckBox"
                                  Content="覆盖已有压缩文件" />
                    </WrapPanel>
                    <TextBlock Text="最大宽高填 0 表示不限制；默认只缩小，不放大。"
                               Grid.Row="1"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               Margin="0,8,0,0"
                               TextWrapping="Wrap" />
                </Grid>
            </Grid>
        </Border>

        <Border Grid.Row="2"
                Style="{StaticResource SectionBorder}"
                Margin="0,12,0,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock x:Name="StatusText"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           FontSize="14"
                           FontWeight="SemiBold"
                           Text="准备就绪" />
                <TextBlock x:Name="SummaryText"
                           Grid.Column="1"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           FontSize="13" />

                <ProgressBar x:Name="ProgressBar"
                             Grid.Row="1"
                             Grid.ColumnSpan="2"
                             Height="12"
                             Minimum="0"
                             Maximum="1"
                             Value="0"
                             Margin="0,10,0,12" />

                <ListBox x:Name="LogListBox"
                         Grid.Row="2"
                         Grid.ColumnSpan="2" />
            </Grid>
        </Border>

        <StackPanel Grid.Row="3"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,14,0,0">
            <Button x:Name="OpenOutputFolderButton"
                    Content="打开输出目录"
                    MinWidth="112"
                    Margin="0,0,8,0"
                    Click="OpenOutputFolderButton_Click" />
            <Button x:Name="OpenLogButton"
                    Content="打开日志"
                    MinWidth="88"
                    IsEnabled="False"
                    Margin="0,0,8,0"
                    Click="OpenLogButton_Click" />
            <Button x:Name="StartButton"
                    Content="开始压缩"
                    MinWidth="104"
                    Margin="0,0,8,0"
                    Click="StartButton_Click" />
            <Button x:Name="CancelRunButton"
                    Content="取消任务"
                    MinWidth="92"
                    IsEnabled="False"
                    Margin="0,0,8,0"
                    Click="CancelRunButton_Click" />
            <Button Content="关闭"
                    MinWidth="84"
                    Click="CloseButton_Click" />
        </StackPanel>
    </Grid>
</Window>
