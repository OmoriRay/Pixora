    <SolidColorBrush x:Key="WarningBorderBrush" Color="#D5A329" />
    <SolidColorBrush x:Key="WarningTextBrush" Color="#745500" />

    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#CFE7F3" />
    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="#16212B" />
    <SolidColorBrush x:Key="{x:Static SystemColors.ControlBrushKey}" Color="#FFFFFF" />
    <SolidColorBrush x:Key="{x:Static SystemColors.ControlTextBrushKey}" Color="#16212B" />
    <SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}" Color="#F3F5F7" />
    <SolidColorBrush x:Key="{x:Static SystemColors.WindowTextBrushKey}" Color="#16212B" />
