<Window x:Class="Pixora.ShortcutSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="设置"
        Width="720"
        Height="540"
        MinWidth="560"
        MinHeight="460"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource AppBackgroundBrush}"
        Foreground="{DynamicResource TextPrimaryBrush}"
        FontFamily="Microsoft YaHei UI"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType"
        TextOptions.TextHintingMode="Fixed"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        PreviewKeyDown="Window_PreviewKeyDown"
        Closing="Window_Closing">
    <Window.Resources>
        <Style x:Key="SettingsNavButton" TargetType="{x:Type RadioButton}">
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
            <Setter Property="Background" Value="{DynamicResource SurfaceRaisedBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderStrongBrush}" />
            <Setter Property="Padding" Value="18,8" />
            <Setter Property="Margin" Value="0,0,6,0" />
            <Setter Property="MinWidth" Value="92" />
            <Setter Property="MinHeight" Value="38" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="FocusVisualStyle" Value="{DynamicResource KeyboardFocusVisual}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type RadioButton}">
                        <Border x:Name="ButtonChrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter ContentSource="Content"
                                              TextElement.Foreground="{TemplateBinding Foreground}"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
                                <Setter TargetName="ButtonChrome" Property="Background" Value="{DynamicResource AccentSurfaceBrush}" />
                                <Setter TargetName="ButtonChrome" Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonChrome" Property="Background" Value="{DynamicResource SurfaceHoverBrush}" />
                                <Setter TargetName="ButtonChrome" Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsChecked" Value="True" />
                                    <Condition Property="IsMouseOver" Value="True" />
                                </MultiTrigger.Conditions>
                                <Setter TargetName="ButtonChrome" Property="Background" Value="{DynamicResource AccentSurfaceBrush}" />
                                <Setter TargetName="ButtonChrome" Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                            </MultiTrigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
                                <Setter TargetName="ButtonChrome" Property="Background" Value="{DynamicResource SurfaceDisabledBrush}" />
                                <Setter TargetName="ButtonChrome" Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="SettingsSection" TargetType="{x:Type Border}">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
            <Setter Property="Padding" Value="4,4,4,18" />
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border HorizontalAlignment="Left"
                    Background="{DynamicResource SurfaceRaisedBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="4">
                <StackPanel Orientation="Horizontal">
                    <RadioButton x:Name="GeneralTabButton"
                                 Content="常规"
                                 GroupName="SettingsPage"
                                 IsChecked="True"
                                 Style="{StaticResource SettingsNavButton}"
                                 Checked="SettingsTab_Checked" />
                    <RadioButton x:Name="ShortcutsTabButton"
                                 Content="快捷键"
                                 GroupName="SettingsPage"
                                 Style="{StaticResource SettingsNavButton}"
                                 Checked="SettingsTab_Checked" />
                </StackPanel>
            </Border>

            <Grid Grid.Row="1"
                  ClipToBounds="True">
                <ScrollViewer x:Name="GeneralPage"
                              Background="{DynamicResource AppBackgroundBrush}"
                              ClipToBounds="True"
                              VerticalScrollBarVisibility="Auto"
                              TextOptions.TextRenderingMode="Grayscale"
                              TextOptions.TextHintingMode="Animated">
                    <Grid Margin="0,12,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="14" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Border x:Name="FileBehaviorSettingsSection"
                                Style="{StaticResource SettingsSection}">
                            <StackPanel>
                                <TextBlock Text="文件行为"
                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                           FontSize="15"
                                           FontWeight="SemiBold" />
                                <TextBlock Text="保存后打开"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           FontSize="12"
                                           Margin="0,14,0,6" />
                                <ComboBox x:Name="SavedFileOpenBehaviorComboBox"
                                          HorizontalAlignment="Stretch"
                                          SelectedValuePath="Tag">
                                    <ComboBoxItem Content="不打开" Tag="None" />
                                    <ComboBoxItem Content="新窗口打开" Tag="NewWindow" />
                                    <ComboBoxItem Content="当前窗口打开" Tag="CurrentWindow" />
                                </ComboBox>
                                <CheckBox x:Name="ConfirmDeleteToRecycleBinCheckBox"
                                          Content="按 Del 删除到回收站前弹出确认"
                                          Margin="0,16,0,0"
                                          Foreground="{DynamicResource TextBodyBrush}" />
                                <CheckBox x:Name="OpenLastFolderOnStartupCheckBox"
                                          Content="启动时自动打开上次目录"
                                          Margin="0,16,0,0"
                                          Foreground="{DynamicResource TextBodyBrush}" />
                                <CheckBox x:Name="ReuseExistingWindowCheckBox"
                                          Content="双击图片时复用已有 Pixora 窗口（重启后生效）"
                                          Margin="0,16,0,0"
                                          Foreground="{DynamicResource TextBodyBrush}" />
                                <CheckBox x:Name="KeepViewStateWhenNavigatingCheckBox"
                                          Content="切换图片时保持当前缩放和位置"
                                          Margin="0,16,0,0"
                                          Foreground="{DynamicResource TextBodyBrush}" />
                                <CheckBox x:Name="WatchFolderChangesCheckBox"
                                          Content="自动刷新外部新增、重命名或删除的文件"
                                          Margin="0,16,0,0"
                                          Foreground="{DynamicResource TextBodyBrush}" />
                                <TextBlock Text="打开目录"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           FontSize="12"
                                           Margin="0,18,0,6" />
                                <TextBlock Text="使用系统文件对话框。进入目标目录后直接点打开即可打开当前目录；也可以选中任意图片或视频，程序会打开它所在的目录。仍可把目录拖入主窗口直接打开。"
                                           Foreground="{DynamicResource TextBodyBrush}"
                                           FontSize="12"
                                           LineHeight="19"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>

                        <Border x:Name="InterfaceSettingsSection"
                                Grid.Column="2"
                                Style="{StaticResource SettingsSection}">
                            <StackPanel>
                                <TextBlock Text="界面"
                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                           FontSize="15"
                                           FontWeight="SemiBold" />
                                <TextBlock Text="外观主题"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           FontSize="12"
                                           Margin="0,14,0,6" />
                                <ComboBox x:Name="ThemeComboBox"
                                          HorizontalAlignment="Stretch"
                                          SelectedValuePath="Tag"
                                          AutomationProperties.Name="外观主题"
                                          SelectionChanged="ThemeComboBox_SelectionChanged">
                                    <ComboBoxItem Content="深色" Tag="Dark" />
                                    <ComboBoxItem Content="亮色" Tag="Light" />
                                </ComboBox>
                                <TextBlock Text="切换后立即预览，保存后下次启动继续使用。"
                                           Foreground="{DynamicResource TextMutedBrush}"
                                           FontSize="11"
                                           Margin="0,7,0,0"
                                           TextWrapping="Wrap" />
                                <CheckBox x:Name="ShowThumbnailSidebarCheckBox"
                                          Content="启动时显示右侧缩略图栏"
                                          Margin="0,14,0,0"
                                          Foreground="{DynamicResource TextBodyBrush}" />
                                <CheckBox x:Name="UseDoubleThumbnailColumnsCheckBox"
                                          Content="使用双列缩略图"
                                          Margin="0,16,0,0"
                                          Foreground="{DynamicResource TextBodyBrush}" />
                                <TextBlock Text="快速搜索默认方式"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           FontSize="12"
                                           Margin="0,16,0,6" />
                                <ComboBox x:Name="QuickSearchModeComboBox"
                                          HorizontalAlignment="Stretch"
                                          SelectedValuePath="Tag">
                                    <ComboBoxItem Content="按图片序号跳转" Tag="Index" />
                                    <ComboBoxItem Content="按文件名查找" Tag="FileName" />
                                </ComboBox>
                                <CheckBox x:Name="ShowQuickSearchOnStartupCheckBox"
                                          Content="启动时自动显示快速搜索"
                                          Margin="0,16,0,0"
                                          Foreground="{DynamicResource TextBodyBrush}" />
                                <CheckBox x:Name="HideQuickSearchAfterJumpCheckBox"
                                          Content="跳转成功后自动收起快速搜索"
                                          Margin="0,16,0,0"
                                          Foreground="{DynamicResource TextBodyBrush}" />
                                <CheckBox x:Name="RememberMainWindowPlacementCheckBox"
                                          Content="记住主窗口大小、位置和最大化状态"
                                          Margin="0,16,0,0"
                                          Foreground="{DynamicResource TextBodyBrush}" />
                                <CheckBox x:Name="StartMainWindowMaximizedCheckBox"
                                          Content="启动时始终最大化主窗口"
                                          Margin="0,16,0,0"
                                          Foreground="{DynamicResource TextBodyBrush}" />
                                <CheckBox x:Name="ShowAnimationControlsCheckBox"
                                          Content="显示动图播放控制"
                                          Margin="0,16,0,0"
                                          Foreground="{DynamicResource TextBodyBrush}" />
                                <CheckBox x:Name="ShowOperationNotificationsCheckBox"
                                          Content="显示操作提示"
                                          Margin="0,16,0,0"
                                          Foreground="{DynamicResource TextBodyBrush}" />
                                <CheckBox x:Name="ShowZoomIndicatorCheckBox"
                                          Content="缩放时显示比例"
                                          Margin="0,16,0,0"
                                          Foreground="{DynamicResource TextBodyBrush}" />
                                <TextBlock Text="缩放提示格式"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           FontSize="12"
                                           Margin="0,12,0,6" />
                                <ComboBox x:Name="ZoomIndicatorDisplayModeComboBox"
                                          HorizontalAlignment="Stretch"
                                          SelectedValuePath="Tag"
                                          IsEnabled="{Binding IsChecked, ElementName=ShowZoomIndicatorCheckBox}">
                                    <ComboBoxItem Content="百分比（相对图片尺寸）" Tag="Percentage" />
                                    <ComboBoxItem Content="相对倍数（适应窗口 = 1.00×）" Tag="Multiplier" />
                                </ComboBox>
                                <TextBlock Text="百分比：100% 表示当前图片或安全预览的原始显示尺寸。相对倍数：以“适应窗口”的默认大小为 1.00×，表示在默认视图基础上放大或缩小了多少。超大图片的百分比以安全预览为基准。"
                                           Foreground="{DynamicResource TextMutedBrush}"
                                           FontSize="11"
                                           Margin="0,7,0,0"
                                           TextWrapping="Wrap" />
                                <CheckBox x:Name="LoadFullResolutionWhenIdleCheckBox"
                                          Content="空闲时后台加载当前原图"
                                          Margin="0,16,0,0"
                                          Foreground="{DynamicResource TextBodyBrush}" />
                            </StackPanel>
                        </Border>

                        <Border x:Name="PerformanceSettingsSection"
                                Grid.Row="1"
                                Grid.Column="2"
                                Margin="0,14,0,0"
                                Style="{StaticResource SettingsSection}">
                            <StackPanel>
                                <TextBlock Text="性能与缓存"
                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                           FontSize="15"
                                           FontWeight="SemiBold" />
                                <TextBlock Text="缓存模式"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           FontSize="12"
                                           Margin="0,14,0,6" />
                                <ComboBox x:Name="CacheSizingModeComboBox"
                                          HorizontalAlignment="Stretch"
                                          SelectedValuePath="Tag"
                                          AutomationProperties.Name="内存缓存模式"
                                          SelectionChanged="CacheSizingModeComboBox_SelectionChanged">
                                    <ComboBoxItem Content="自动（推荐）" Tag="Automatic" />
                                    <ComboBoxItem Content="手动" Tag="Manual" />
                                </ComboBox>
                                <Border x:Name="AutomaticCacheSummaryPanel"
                                        Margin="0,10,0,0"
                                        Padding="12,10"
                                        Background="{DynamicResource InfoSurfaceBrush}"
                                        BorderBrush="{DynamicResource InfoBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="7">
                                    <StackPanel>
                                        <TextBlock Text="已根据本机硬件自动配置"
                                                   Foreground="{DynamicResource InfoTitleBrush}"
                                                   FontSize="12"
                                                   FontWeight="SemiBold" />
                                        <TextBlock x:Name="AutomaticCacheSummaryText"
                                           Margin="0,4,0,0"
                                                   Foreground="{DynamicResource InfoTextBrush}"
                                                   FontSize="11"
                                                   AutomationProperties.Name="当前自动缓存配置"
                                                   AutomationProperties.LiveSetting="Polite"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>
                                </Border>
                                <StackPanel x:Name="ManualCacheSettingsPanel"
                                            Margin="0,2,0,0">
                                    <TextBlock Text="手动原图缓存"
                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                               FontSize="12"
                                               Margin="0,12,0,6" />
                                    <ComboBox x:Name="MainImageCacheComboBox"
                                              HorizontalAlignment="Stretch"
                                              SelectedValuePath="Tag">
                                        <ComboBoxItem Content="512 MB" Tag="512" />
                                        <ComboBoxItem Content="768 MB" Tag="768" />
                                        <ComboBoxItem Content="1 GB" Tag="1024" />
                                        <ComboBoxItem Content="2 GB" Tag="2048" />
                                        <ComboBoxItem Content="4 GB" Tag="4096" />
                                        <ComboBoxItem Content="8 GB" Tag="8192" />
                                    </ComboBox>
                                    <TextBlock Text="手动预览缓存"
                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                               FontSize="12"
                                               Margin="0,12,0,6" />
                                    <ComboBox x:Name="DisplayPreviewCacheComboBox"
                                              HorizontalAlignment="Stretch"
                                              SelectedValuePath="Tag">
                                        <ComboBoxItem Content="128 MB" Tag="128" />
                                        <ComboBoxItem Content="192 MB" Tag="192" />
                                        <ComboBoxItem Content="256 MB" Tag="256" />
                                        <ComboBoxItem Content="512 MB" Tag="512" />
                                        <ComboBoxItem Content="1 GB" Tag="1024" />
                                        <ComboBoxItem Content="2 GB" Tag="2048" />
                                    </ComboBox>
                                </StackPanel>
                                <CheckBox x:Name="LowMemoryProtectionCheckBox"
                                          Content="低内存时自动减少后台加载和缓存"
                                          Margin="0,16,0,0"
                                          Foreground="{DynamicResource TextBodyBrush}" />
                                <CheckBox x:Name="ThumbnailDiskCacheCheckBox"
                                          Content="使用缩略图磁盘缓存"
                                          Margin="0,16,0,0"
                                          Foreground="{DynamicResource TextBodyBrush}" />
                                <TextBlock Text="缩略图磁盘缓存上限"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           FontSize="12"
                                           Margin="0,12,0,6" />
                                <ComboBox x:Name="ThumbnailDiskCacheSizeComboBox"
                                          HorizontalAlignment="Stretch"
                                          SelectedValuePath="Tag">
                                    <ComboBoxItem Content="256 MB" Tag="256" />
                                    <ComboBoxItem Content="512 MB" Tag="512" />
                                    <ComboBoxItem Content="1 GB" Tag="1024" />
                                    <ComboBoxItem Content="2 GB" Tag="2048" />
                                </ComboBox>
                                <WrapPanel Orientation="Horizontal"
                                           Margin="0,10,0,0">
                                    <Button x:Name="ClearThumbnailDiskCacheButton"
                                            Content="清理缩略图缓存"
                                            MinWidth="116"
                                            AutomationProperties.Name="清理缩略图磁盘缓存"
                                            Click="ClearThumbnailDiskCacheButton_Click" />
                                </WrapPanel>
                                <TextBlock x:Name="ThumbnailDiskCachePathText"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           FontSize="11"
                                           AutomationProperties.LiveSetting="Polite"
                                           TextWrapping="Wrap"
                                           Margin="26,6,0,0" />
                            </StackPanel>
                        </Border>

                        <Border x:Name="DiagnosticsSettingsSection"
                                Grid.Row="1"
                                Grid.Column="0"
                                Margin="0,14,0,0"
                                Style="{StaticResource SettingsSection}">
                            <StackPanel>
                                <TextBlock Text="诊断与关于"
                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                           FontSize="15"
                                           FontWeight="SemiBold" />
                                <TextBlock x:Name="AppVersionText"
                                           Margin="0,14,0,0"
                                           Foreground="{DynamicResource TextBodyBrush}"
                                           FontSize="12" />
                                <CheckBox x:Name="IncludePrivatePathsInDiagnosticsCheckBox"
                                          Content="诊断信息包含本机完整路径（默认隐藏）"
                                          Margin="0,14,0,0"
                                          Foreground="{DynamicResource TextBodyBrush}" />
                                <WrapPanel Orientation="Horizontal"
                                           Margin="0,14,0,0">
                                    <Button Content="打开错误日志位置"
                                            MinWidth="116"
                                            Margin="0,0,8,0"
                                            Click="OpenErrorLogFolderButton_Click" />
                                    <Button Content="复制诊断信息"
                                            MinWidth="116"
                                            Click="CopyDiagnosticsButton_Click" />
                                </WrapPanel>
                            </StackPanel>
                        </Border>

                        <Border x:Name="FileAssociationsSettingsSection"
                                Grid.Row="2"
                                Grid.ColumnSpan="3"
                                Style="{StaticResource SettingsSection}"
                                Margin="0,14,0,0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <TextBlock Text="文件关联"
                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                           FontSize="15"
                                           FontWeight="SemiBold" />
                                <TextBlock Text="先尝试直接把常见图片格式设为默认应用；当前 Windows 不支持时，会打开默认应用设置页。"
                                           Grid.Row="1"
                                           Margin="0,8,0,0"
                                           Foreground="{DynamicResource TextBodyBrush}"
                                           FontSize="12"
                                           TextWrapping="Wrap" />
                                <StackPanel Grid.Row="2"
                                            Orientation="Horizontal"
                                            Margin="0,14,0,0">
                                    <Button Content="关联常见图片格式"
                                            MinWidth="132"
                                            Margin="0,0,8,0"
                                            Click="RegisterFileAssociationsButton_Click" />
                                    <Button Content="关联并设为默认应用"
                                            MinWidth="160"
                                            Margin="0,0,8,0"
                                            Click="RegisterAndOpenDefaultAppsButton_Click" />
                                    <Button Content="高级一键默认"
                                            MinWidth="124"
                                            Margin="0,0,8,0"
                                            Click="AdvancedDefaultAssociationsButton_Click" />
                                    <Button Content="取消关联"
                                            MinWidth="88"
                                            Click="UnregisterFileAssociationsButton_Click" />
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Grid>
                </ScrollViewer>
                <Grid x:Name="ShortcutsPage"
                      Margin="0,12,0,0"
                      Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Background="{DynamicResource SurfaceBrush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="1">
                        <ListBox x:Name="ShortcutGrid"
                                 Background="{DynamicResource SurfaceBrush}"
                                 Foreground="{DynamicResource TextPrimaryBrush}"
                                 BorderThickness="0"
                                 FontFamily="Microsoft YaHei UI"
                                 FontSize="13"
                                 AlternationCount="2"
                                 HorizontalContentAlignment="Stretch"
                                 ScrollViewer.CanContentScroll="False"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                                 TextOptions.TextRenderingMode="Grayscale"
                                 TextOptions.TextHintingMode="Animated"
                                 SelectionChanged="ShortcutGrid_SelectionChanged"
                                 Loaded="ShortcutGrid_Loaded"
                                 SizeChanged="ShortcutGrid_SizeChanged"
                                 Tag="320">
                            <ListBox.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Horizontal" />
                                </ItemsPanelTemplate>
                            </ListBox.ItemsPanel>
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="{x:Type ListBoxItem}">
                                    <Setter Property="Width" Value="{Binding Tag, RelativeSource={RelativeSource AncestorType={x:Type ListBox}}}" />
                                    <Setter Property="MinHeight" Value="30" />
                                    <Setter Property="Margin" Value="0,0,8,4" />
                                    <Setter Property="Padding" Value="10,4" />
                                    <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
                                    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                    <Setter Property="VerticalContentAlignment" Value="Center" />
                                    <Setter Property="FocusVisualStyle" Value="{DynamicResource KeyboardFocusVisual}" />
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="{x:Type ListBoxItem}">
                                                <Border x:Name="ItemChrome"
                                                        Background="{TemplateBinding Background}"
                                                        Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                                      VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="ItemsControl.AlternationIndex" Value="1">
                                                        <Setter TargetName="ItemChrome" Property="Background" Value="{DynamicResource SurfaceHoverBrush}" />
                                                    </Trigger>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="ItemChrome" Property="Background" Value="{DynamicResource AccentSurfaceHoverBrush}" />
                                                    </Trigger>
                                                    <Trigger Property="IsSelected" Value="True">
                                                        <Setter Property="Foreground" Value="{DynamicResource SelectionTextBrush}" />
                                                        <Setter TargetName="ItemChrome" Property="Background" Value="{DynamicResource SelectionBrush}" />
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding CategoryText}"
                                                   Width="30"
                                                   Margin="0,0,8,0"
                                                   VerticalAlignment="Center"
                                                   Foreground="{DynamicResource TextMutedBrush}"
                                                   FontSize="11"
                                                   TextTrimming="CharacterEllipsis" />
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding ActionName}"
                                                   VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis" />
                                        <TextBlock Grid.Column="2"
                                                   Text="{Binding ShortcutText}"
                                                   Margin="14,0,0,0"
                                                   VerticalAlignment="Center"
                                                   TextAlignment="Right"
                                                   TextTrimming="CharacterEllipsis" />
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Border>
                </Grid>
            </Grid>
        </Grid>

        <Grid Grid.Row="1"
              Margin="0,14,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock x:Name="StatusText"
                       Margin="2,0,12,0"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       Text="选择一行后可以修改、添加或删除单个快捷键。"
                       TextTrimming="CharacterEllipsis"
                       Visibility="Collapsed" />

            <StackPanel x:Name="ShortcutActionButtonsPanel"
