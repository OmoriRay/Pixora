<Window x:Class="Pixora.ShortcutSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="设置"
        Width="720"
        Height="540"
        MinWidth="560"
        MinHeight="460"
        WindowStartupLocation="CenterOwner"
        Background="#101216"
        Foreground="#F2F5F7"
        FontFamily="Microsoft YaHei UI"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType"
        TextOptions.TextHintingMode="Fixed"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        PreviewKeyDown="Window_PreviewKeyDown"
        Closing="Window_Closing">
    <Window.Resources>
        <Style x:Key="SettingsNavButton" TargetType="{x:Type RadioButton}">
            <Setter Property="Foreground" Value="#AEB8C4" />
            <Setter Property="Background" Value="#15191F" />
            <Setter Property="BorderBrush" Value="#303A48" />
            <Setter Property="Padding" Value="18,8" />
            <Setter Property="Margin" Value="0,0,6,0" />
            <Setter Property="MinWidth" Value="92" />
            <Setter Property="MinHeight" Value="38" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type RadioButton}">
                        <Border x:Name="ButtonChrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter ContentSource="Content"
                                              TextElement.Foreground="{TemplateBinding Foreground}"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter Property="Foreground" Value="#F2F5F7" />
                                <Setter TargetName="ButtonChrome" Property="Background" Value="#213142" />
                                <Setter TargetName="ButtonChrome" Property="BorderBrush" Value="#65BFF2" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonChrome" Property="Background" Value="#1B222B" />
                                <Setter TargetName="ButtonChrome" Property="BorderBrush" Value="#65BFF2" />
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsChecked" Value="True" />
                                    <Condition Property="IsMouseOver" Value="True" />
                                </MultiTrigger.Conditions>
                                <Setter TargetName="ButtonChrome" Property="Background" Value="#213142" />
                                <Setter TargetName="ButtonChrome" Property="BorderBrush" Value="#65BFF2" />
                            </MultiTrigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#788290" />
                                <Setter TargetName="ButtonChrome" Property="Background" Value="#141820" />
                                <Setter TargetName="ButtonChrome" Property="BorderBrush" Value="#2A3340" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border HorizontalAlignment="Left"
                    Background="#12161D"
                    BorderBrush="#273241"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="4">
                <StackPanel Orientation="Horizontal">
                    <RadioButton x:Name="GeneralTabButton"
                                 Content="常规"
                                 GroupName="SettingsPage"
                                 IsChecked="True"
                                 Style="{StaticResource SettingsNavButton}"
                                 Checked="SettingsTab_Checked" />
                    <RadioButton x:Name="ShortcutsTabButton"
                                 Content="快捷键"
                                 GroupName="SettingsPage"
                                 Style="{StaticResource SettingsNavButton}"
                                 Checked="SettingsTab_Checked" />
                </StackPanel>
            </Border>

            <Grid Grid.Row="1">
                <ScrollViewer x:Name="GeneralPage"
                              VerticalScrollBarVisibility="Auto">
                    <Grid Margin="0,12,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="14" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Border Background="#171A20"
                                BorderBrush="#2F3B48"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="16">
                            <StackPanel>
                                <TextBlock Text="文件行为"
                                           Foreground="#F2F5F7"
                                           FontSize="15"
                                           FontWeight="SemiBold" />
                                <TextBlock Text="保存后打开"
                                           Foreground="#AEB8C4"
                                           FontSize="12"
                                           Margin="0,14,0,6" />
                                <ComboBox x:Name="SavedFileOpenBehaviorComboBox"
                                          HorizontalAlignment="Stretch"
                                          SelectedValuePath="Tag">
                                    <ComboBoxItem Content="不打开" Tag="None" />
                                    <ComboBoxItem Content="新窗口打开" Tag="NewWindow" />
                                    <ComboBoxItem Content="当前窗口打开" Tag="CurrentWindow" />
                                </ComboBox>
                                <CheckBox x:Name="ConfirmDeleteToRecycleBinCheckBox"
                                          Content="按 Del 删除到回收站前弹出确认"
                                          Margin="0,16,0,0"
                                          Foreground="#DCE4EC" />
                                <CheckBox x:Name="OpenLastFolderOnStartupCheckBox"
                                          Content="启动时自动打开上次目录"
                                          Margin="0,16,0,0"
                                          Foreground="#DCE4EC" />
                                <TextBlock Text="打开目录"
                                           Foreground="#AEB8C4"
                                           FontSize="12"
                                           Margin="0,18,0,6" />
                                <TextBlock Text="使用系统文件对话框。进入目标目录后直接点打开即可打开当前目录；也可以选中任意图片或视频，程序会打开它所在的目录。仍可把目录拖入主窗口直接打开。"
                                           Foreground="#DCE4EC"
                                           FontSize="12"
                                           LineHeight="19"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>

                        <Border Background="#171A20"
                                Grid.Column="2"
                                BorderBrush="#2F3B48"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="16">
                            <StackPanel>
                                <TextBlock Text="界面"
                                           Foreground="#F2F5F7"
                                           FontSize="15"
                                           FontWeight="SemiBold" />
                                <CheckBox x:Name="ShowThumbnailSidebarCheckBox"
                                          Content="启动时显示右侧缩略图栏"
                                          Margin="0,14,0,0"
                                          Foreground="#DCE4EC" />
                                <CheckBox x:Name="UseDoubleThumbnailColumnsCheckBox"
                                          Content="使用双列缩略图"
                                          Margin="0,16,0,0"
                                          Foreground="#DCE4EC" />
                                <CheckBox x:Name="ShowDirectoryStatsCheckBox"
                                          Content="显示当前目录统计信息"
                                          Margin="0,16,0,0"
                                          Foreground="#DCE4EC" />
                                <CheckBox x:Name="ShowAnimationControlsCheckBox"
                                          Content="显示动图播放控制"
                                          Margin="0,16,0,0"
                                          Foreground="#DCE4EC" />
                                <CheckBox x:Name="ShowOperationNotificationsCheckBox"
                                          Content="显示操作提示"
                                          Margin="0,16,0,0"
                                          Foreground="#DCE4EC" />
                                <CheckBox x:Name="LoadFullResolutionWhenIdleCheckBox"
                                          Content="空闲时后台加载当前原图"
                                          Margin="0,16,0,0"
                                          Foreground="#DCE4EC" />
                                <TextBlock Text="性能"
                                           Foreground="#AEB8C4"
                                           FontSize="12"
                                           Margin="0,18,0,6" />
                                <TextBlock Text="原图缓存"
                                           Foreground="#AEB8C4"
                                           FontSize="12"
                                           Margin="0,0,0,6" />
                                <ComboBox x:Name="MainImageCacheComboBox"
                                          HorizontalAlignment="Stretch"
                                          SelectedValuePath="Tag">
                                    <ComboBoxItem Content="512 MB" Tag="512" />
                                    <ComboBoxItem Content="768 MB" Tag="768" />
                                    <ComboBoxItem Content="1 GB" Tag="1024" />
                                    <ComboBoxItem Content="2 GB" Tag="2048" />
                                </ComboBox>
                                <TextBlock Text="预览缓存"
                                           Foreground="#AEB8C4"
                                           FontSize="12"
                                           Margin="0,12,0,6" />
                                <ComboBox x:Name="DisplayPreviewCacheComboBox"
                                          HorizontalAlignment="Stretch"
                                          SelectedValuePath="Tag">
                                    <ComboBoxItem Content="128 MB" Tag="128" />
                                    <ComboBoxItem Content="192 MB" Tag="192" />
                                    <ComboBoxItem Content="256 MB" Tag="256" />
                                    <ComboBoxItem Content="512 MB" Tag="512" />
                                </ComboBox>
                                <CheckBox x:Name="LowMemoryProtectionCheckBox"
                                          Content="低内存时自动减少后台加载和缓存"
                                          Margin="0,16,0,0"
                                          Foreground="#DCE4EC" />
                                <CheckBox x:Name="ThumbnailDiskCacheCheckBox"
                                          Content="使用缩略图磁盘缓存"
                                          Margin="0,16,0,0"
                                          Foreground="#DCE4EC" />
                                <TextBlock Text="缩略图磁盘缓存上限"
                                           Foreground="#AEB8C4"
                                           FontSize="12"
                                           Margin="0,12,0,6" />
                                <ComboBox x:Name="ThumbnailDiskCacheSizeComboBox"
                                          HorizontalAlignment="Stretch"
                                          SelectedValuePath="Tag">
                                    <ComboBoxItem Content="256 MB" Tag="256" />
                                    <ComboBoxItem Content="512 MB" Tag="512" />
                                    <ComboBoxItem Content="1 GB" Tag="1024" />
                                    <ComboBoxItem Content="2 GB" Tag="2048" />
                                </ComboBox>
                                <StackPanel Orientation="Horizontal"
                                            Margin="0,10,0,0">
                                    <Button Content="清理缩略图缓存"
                                            MinWidth="116"
                                            Margin="0,0,8,0"
                                            Click="ClearThumbnailDiskCacheButton_Click" />
                                    <Button Content="打开错误日志位置"
                                            MinWidth="116"
                                            Click="OpenErrorLogFolderButton_Click" />
                                </StackPanel>
                                <TextBlock x:Name="ThumbnailDiskCachePathText"
                                           Foreground="#AEB8C4"
                                           FontSize="11"
                                           TextWrapping="Wrap"
                                           Margin="26,6,0,0" />
                                <TextBlock Text="关于"
                                           Foreground="#AEB8C4"
                                           FontSize="12"
                                           Margin="0,18,0,6" />
                                <TextBlock x:Name="AppVersionText"
                                           Foreground="#DCE4EC"
                                           FontSize="12" />
                            </StackPanel>
                        </Border>

                        <Border Grid.Row="1"
                                Grid.ColumnSpan="3"
                                Background="#171A20"
                                BorderBrush="#2F3B48"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="16"
                                Margin="0,14,0,0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <TextBlock Text="文件关联"
                                           Foreground="#F2F5F7"
                                           FontSize="15"
                                           FontWeight="SemiBold" />
                                <TextBlock Text="先尝试直接把常见图片格式设为默认应用；当前 Windows 不支持时，会打开默认应用设置页。"
                                           Grid.Row="1"
                                           Margin="0,8,0,0"
                                           Foreground="#DCE4EC"
                                           FontSize="12"
                                           TextWrapping="Wrap" />
                                <StackPanel Grid.Row="2"
                                            Orientation="Horizontal"
                                            Margin="0,14,0,0">
                                    <Button Content="关联常见图片格式"
                                            MinWidth="132"
                                            Margin="0,0,8,0"
                                            Click="RegisterFileAssociationsButton_Click" />
                                    <Button Content="关联并设为默认应用"
                                            MinWidth="160"
                                            Margin="0,0,8,0"
                                            Click="RegisterAndOpenDefaultAppsButton_Click" />
                                    <Button Content="高级一键默认"
                                            MinWidth="124"
                                            Margin="0,0,8,0"
                                            Click="AdvancedDefaultAssociationsButton_Click" />
                                    <Button Content="取消关联"
                                            MinWidth="88"
                                            Click="UnregisterFileAssociationsButton_Click" />
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Grid>
                </ScrollViewer>
                <Grid x:Name="ShortcutsPage"
                      Margin="0,12,0,0"
                      Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Background="#171A20"
                            BorderBrush="#2F3B48"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="1">
                        <ListBox x:Name="ShortcutGrid"
                                 Background="#171A20"
                                 Foreground="#F2F5F7"
                                 BorderThickness="0"
                                 FontFamily="Microsoft YaHei UI"
                                 FontSize="13"
                                 AlternationCount="2"
                                 HorizontalContentAlignment="Stretch"
                                 ScrollViewer.CanContentScroll="False"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                                 SelectionChanged="ShortcutGrid_SelectionChanged"
                                 Loaded="ShortcutGrid_Loaded"
                                 SizeChanged="ShortcutGrid_SizeChanged"
                                 Tag="320">
                            <ListBox.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Horizontal" />
                                </ItemsPanelTemplate>
                            </ListBox.ItemsPanel>
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="{x:Type ListBoxItem}">
                                    <Setter Property="Width" Value="{Binding Tag, RelativeSource={RelativeSource AncestorType={x:Type ListBox}}}" />
                                    <Setter Property="MinHeight" Value="30" />
                                    <Setter Property="Margin" Value="0,0,8,4" />
                                    <Setter Property="Padding" Value="10,4" />
                                    <Setter Property="Background" Value="#171A20" />
                                    <Setter Property="Foreground" Value="#F2F5F7" />
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                    <Setter Property="VerticalContentAlignment" Value="Center" />
                                    <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="{x:Type ListBoxItem}">
                                                <Border x:Name="ItemChrome"
                                                        Background="{TemplateBinding Background}"
                                                        Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                                      VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="ItemsControl.AlternationIndex" Value="1">
                                                        <Setter TargetName="ItemChrome" Property="Background" Value="#1C2028" />
                                                    </Trigger>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="ItemChrome" Property="Background" Value="#223142" />
                                                    </Trigger>
                                                    <Trigger Property="IsSelected" Value="True">
                                                        <Setter Property="Foreground" Value="#FFFFFF" />
                                                        <Setter TargetName="ItemChrome" Property="Background" Value="#2D4A62" />
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding CategoryText}"
                                                   Width="30"
                                                   Margin="0,0,8,0"
                                                   VerticalAlignment="Center"
                                                   Foreground="#8FA0B2"
                                                   FontSize="11"
                                                   TextTrimming="CharacterEllipsis" />
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding ActionName}"
                                                   VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis" />
                                        <TextBlock Grid.Column="2"
                                                   Text="{Binding ShortcutText}"
                                                   Margin="14,0,0,0"
                                                   VerticalAlignment="Center"
                                                   TextAlignment="Right"
                                                   TextTrimming="CharacterEllipsis" />
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Border>
                </Grid>
            </Grid>
        </Grid>

        <Grid Grid.Row="1"
              Margin="0,14,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock x:Name="StatusText"
                       Margin="2,0,12,0"
                       VerticalAlignment="Center"
                       Foreground="#AEB8C4"
                       Text="选择一行后可以修改、添加或删除单个快捷键。"
                       TextTrimming="CharacterEllipsis"
                       Visibility="Collapsed" />

            <StackPanel x:Name="ShortcutActionButtonsPanel"
                        Grid.Column="1"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,0,16,0"
                        Visibility="Collapsed">
                <Button x:Name="EditButton"
                        Content="修改"
                        MinWidth="84"
                        Padding="12,7"
                        Margin="0,0,8,0"
                        Click="EditButton_Click" />
                <Button x:Name="AddButton"
                        Content="添加"
                        MinWidth="84"
                        Padding="12,7"
                        Margin="0,0,8,0"
                        Click="AddButton_Click" />
                <Button x:Name="DeleteButton"
                        Content="删除选中"
                        MinWidth="94"
                        Padding="12,7"
                        Margin="0,0,8,0"
                        Click="DeleteButton_Click" />
                <Button Content="恢复默认"
                        MinWidth="84"
                        Padding="12,7"
                        Margin="0,0,8,0"
                        Click="ResetButton_Click" />
                <Button Content="清空所有"
                        MinWidth="84"
                        Padding="12,7"
                        Click="ClearAllButton_Click" />
            </StackPanel>

            <StackPanel Grid.Column="2"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right">
                <Button Content="保存"
                        MinWidth="84"
                        Padding="12,7"
                        Margin="0,0,8,0"
                        Click="SaveButton_Click" />
                <Button Content="取消"
                        MinWidth="84"
                        Padding="12,7"
                        Click="CancelButton_Click" />
            </StackPanel>
        </Grid>
    </Grid>
</Window>
